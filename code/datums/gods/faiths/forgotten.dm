/datum/faith/angros
	name = "\improper Angros"
	desc = "Those who still believe in the fallen Fire God, Angros. These vary between those who are sanctified by the church and extremists who are not. The former exists as an extension of the Katholikos to empower His remains and keep the Worldflame asunder. The latter is anyone who seeks to return Angros to his place as the God of Fire."
	godhead = /datum/patron/angros
